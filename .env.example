# =============================================================================
#  .env  —  Environment Variables
#  Copy to node_gateway/.env  AND  fastapi_engine/.env
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/carbon_db

# ── FastAPI async DSN (asyncpg) ───────────────────────────────
# (Used in fastapi_engine if you add SQLAlchemy async DB)
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/carbon_db

# ── Node.js → FastAPI bridge ──────────────────────────────────
FASTAPI_URL=http://localhost:8000

# ── JWT secrets (change to strong random strings in production) ─
JWT_SECRET=your-256-bit-random-secret-here
JWT_REFRESH_SECRET=your-refresh-256-bit-secret-here

# ── Node.js ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001
